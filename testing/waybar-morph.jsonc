// Minimal Waybar config for morph (ext-workspace-v1).
// Requires a Waybar build with the ext/workspaces module (not the default wlr/workspaces).
//
// Run from another VT or nested session, after morph sets WAYLAND_DISPLAY:
//   waybar -c "$(pwd)/config/waybar-morph.jsonc" -s "$(pwd)/config/waybar-morph.css"
//
// Workspace names from morph are "1".."9"; stable ids are morph-ws-0 .. morph-ws-9.

{
  "layer": "top",
  "position": "top",
  "height": 28,
  "spacing": 6,
  "margin-top": 0,
  "margin-left": 8,
  "margin-right": 8,

  "modules-left": ["ext/workspaces"],
  "modules-center": ["wlr/taskbar"],
  "modules-right": ["clock"],

  "ext/workspaces": {
    "format": "{name}",
    "tooltip-format": "{name} — id {id}",
    "on-click": "activate",
    "sort-by-coordinates": true,
    "all-outputs": true,
    "format-icons": {
      "active": "●",
      "default": "○"
    }
  },

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 16,
    "spacing": 6,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": ["waybar"]
  },

  "clock": {
    "interval": 1,
    "format": "{:%H:%M:%S}",
    "tooltip-format": "<big>{:%Y-%m-%d}</big>\n<tt>{calendar}</tt>"
  }
}
