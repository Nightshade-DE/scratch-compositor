#!/bin/sh
# Main stackcomp startup script.
# - Sets environment variables and logging.
# - Supports nested mode (inside X11/Wayland) and native mode (TTY).
# - Can run test clients in nested mode.
# - Starts compositor, checks exit code, and logs crashes.
# - Sources shared helpers from scripts/shell-helpers.sh.
# - Uses log_startup <level> <message> to write to
#   $STACKCOMP_STARTUP_LOG_FILE.
# - Starts shutdown script automatically after compositor exits.
################################################################################

# Get the root path of the project
REAL_SCRIPT_PATH=$(readlink -f "$0")
FILE_DIR=$(dirname "$REAL_SCRIPT_PATH")
COMP_ROOT_DIR=$(dirname "$FILE_DIR")
export COMP_ROOT_DIR

# Environment variables
# ==============================================================================
# Wlroots debugging (1 for a complete Wayland protocol dump)
export WAYLAND_DEBUG=1

# Enables detailed wlroots logging
export WLR_LOGTS=1

# Java tiling/Wayland compatibility fixes
export _JAVA_AWT_WM_NONREPARENTING=1

# WMNAME=LG3D is a known Java workaround so WM-managed windows (e.g. in i3)
# are handled correctly. LG3D refers to "Project Looking Glass 3D" from Sun.
export WMNAME="LG3D"

# Load shared helper functions before first use.
. "$COMP_ROOT_DIR/scripts/shell-helpers.sh"


# Path Definitions and Log Setup
# ==============================================================================
# Use absolute paths under HOME to avoid /tmp permission issues.
CONFIG_FILE="$COMP_ROOT_DIR/testing/stackcomp.conf"
LOG_DIR="$HOME/.local/share/stackcomp"
LOG_FILE="$LOG_DIR/stackcomp.log"
CRASH_LOG_FILE="$LOG_DIR/stackcomp-crash.log"
SESSION_MODE_NOTE=""
X11_PROBE_NOTE=""
STARTUP_LOG_BASELINE=0
CORE_LOG_BASELINE=0
CRASH_LOG_BASELINE=0
CHOSEN_X11_DISPLAY=""

# Create log directory if it does not exist
mkdir -p "$LOG_DIR"


# Current session detection and mode setup
# ==============================================================================
if choose_reachable_x11_display; then
    # X11 session: register compositor as "wayland-nested".
    export DISPLAY="$CHOSEN_X11_DISPLAY"
    export WLR_BACKENDS=x11
    export WLR_WL_SOCKET="wayland-nested"
    SESSION_MODE_NOTE="nested-x11"
    echo "Starting in Nested-Mode under X11 (DISPLAY=$CHOSEN_X11_DISPLAY)..."
elif [ -n "$WAYLAND_DISPLAY" ]; then
    # Wayland session: use "wayland-nested" to avoid socket collisions.
    export WLR_BACKENDS=wayland
    export WLR_WL_SOCKET="wayland-nested"
    SESSION_MODE_NOTE="nested-wayland"
    echo "Starting in Nested-Mode under Wayland..."
else
    # Console (TTY) or unreachable nested displays: run native backend stack.
    if [ -n "$DISPLAY" ]; then
        echo "DISPLAY=$DISPLAY is unreachable and no WAYLAND_DISPLAY found; falling back to native backend."
    fi
    unset DISPLAY
    export WLR_BACKENDS=drm,libinput
    unset WLR_WL_SOCKET
    SESSION_MODE_NOTE="native-tty"
fi

# Use separate logs in nested mode to avoid overwriting main logs.
if [ "$WLR_BACKENDS" = "x11" ] || [ "$WLR_BACKENDS" = "wayland" ]; then
    export STACKCOMP_STARTUP_LOG_FILE="$LOG_DIR/stackcomp-nested-startup.log"
    export STACKCOMP_SHUTDOWN_LOG_FILE="$LOG_DIR/stackcomp-nested-shutdown.log"
else
    export STACKCOMP_STARTUP_LOG_FILE="$LOG_DIR/stackcomp-startup.log"
    export STACKCOMP_SHUTDOWN_LOG_FILE="$LOG_DIR/stackcomp-shutdown.log"
fi

# Activate Helper functions for logging and launching services
export CURRENT_LOG_FILE="$STACKCOMP_STARTUP_LOG_FILE"

# Capture per-file baselines so the error summary only scans this run.
STARTUP_LOG_BASELINE=$(line_count_or_zero "$STACKCOMP_STARTUP_LOG_FILE")
CORE_LOG_BASELINE=$(line_count_or_zero "$LOG_FILE")
CRASH_LOG_BASELINE=$(line_count_or_zero "$CRASH_LOG_FILE")

# Dynamic program list shared by startup.sh and shutdown.sh for shutdown cleanup.
export STACKCOMP_SHUTDOWN_LIST="$LOG_DIR/shutdown_list.txt"
# Clear shutdown list at startup to avoid leftovers from previous sessions
: > "$STACKCOMP_SHUTDOWN_LIST"
log_startup INFO "============================= N E W  S T A R T ================================"
log_startup INFO "Cleared shutdown list file."


# Startup Summary
# ==============================================================================
log_startup INFO "Environment variables summary:"
log_startup INFO "--------------------------------------------------------------------------------"
log_startup INFO "Selected session mode:        $SESSION_MODE_NOTE"
log_startup INFO "X11 probe details:            $X11_PROBE_NOTE"
log_startup INFO "WLR_BACKENDS:                 $WLR_BACKENDS..."
log_startup INFO "WLR_WL_SOCKET:                $WLR_WL_SOCKET"
log_startup INFO "WAYLAND_DEBUG:                $WAYLAND_DEBUG"
log_startup INFO "WLR_LOGTS:                    $WLR_LOGTS"
log_startup INFO "_JAVA_AWT_WM_NONREPARENTING:  $_JAVA_AWT_WM_NONREPARENTING"
log_startup INFO "WMNAME:                       $WMNAME"

log_startup INFO "Compositors root path:        $COMP_ROOT_DIR"
log_startup INFO "Config file path:             $CONFIG_FILE"
log_startup INFO "Log file path:                $LOG_FILE"
log_startup INFO "Crash log file path:          $CRASH_LOG_FILE"

log_startup INFO "Startup log file:             $STACKCOMP_STARTUP_LOG_FILE"
log_startup INFO "Shutdown log file:            $STACKCOMP_SHUTDOWN_LOG_FILE"


# Compositor start and monitoring
# ==============================================================================
# Start compositor (without exec to get exit code)
log_startup INFO "Execution command: $COMP_ROOT_DIR/build/stackcomp -c \"$CONFIG_FILE\" --log-level debug --log-file \"$LOG_FILE\" --crash-log \"$CRASH_LOG_FILE\""
log_startup INFO "Capturing compositor stdout/stderr into startup log: $STACKCOMP_STARTUP_LOG_FILE"
run_stackcomp_with_capture
EXIT_CODE=$?

# Check exit status for crash detection.
if [ $EXIT_CODE -eq 0 ]; then
    log_startup INFO "Compositor exited normally with exit code 0."
else
    log_startup ERROR "Compositor crashed or exited with an error! Exit code: $EXIT_CODE"
    if [ "$EXIT_CODE" -eq 137 ]; then
        log_startup ERROR "Exit 137 means SIGKILL (often debugger stop, external kill, or OOM killer)."
    fi
    log_startup ERROR "Check the detailed crash log at: $CRASH_LOG_FILE"
    dump_recent_error_summary
fi


# Automatically trigger the shutdown script
# ==============================================================================
log_startup INFO "Triggering session shutdown script..."
if [ -f "$COMP_ROOT_DIR/scripts/shutdown.sh" ]; then
    "$COMP_ROOT_DIR/scripts/shutdown.sh"
else
    log_startup WARN "shutdown.sh not found at expected path!"
fi